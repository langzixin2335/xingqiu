# 短信验证码通道（三选一）
# SMS_PROVIDER=dev          # 开发模式，固定验证码 123456
# SMS_PROVIDER=aliyun       # 阿里云短信
# SMS_PROVIDER=tencent      # 腾讯云短信
# DEV_SMS_CODE=123456

# --- 阿里云短信（SMS_PROVIDER=aliyun）---
# 控制台：https://dysms.console.aliyun.com/
# 1. 申请签名（如「趁早行动」）并通过审核
# 2. 申请模板，变量名须为 ${code}，例如：您的验证码为${code}，5分钟内有效
# 3. 创建 RAM 用户并授予 AliyunDysmsFullAccess，获取 AccessKey
# ALIYUN_ACCESS_KEY_ID=LTAIxxx
# ALIYUN_ACCESS_KEY_SECRET=xxx
# ALIYUN_SMS_SIGN_NAME=趁早行动
# ALIYUN_SMS_TEMPLATE_CODE=SMS_123456789
# ALIYUN_SMS_REGION=cn-hangzhou

# --- 腾讯云短信（SMS_PROVIDER=tencent）---
# 控制台：https://console.cloud.tencent.com/smsv2
# 1. 创建应用，获取 SdkAppId
# 2. 申请签名和模板（模板变量 {1} 对应验证码）
# TENCENT_SECRET_ID=AKIDxxx
# TENCENT_SECRET_KEY=xxx
# TENCENT_SMS_APP_ID=1400xxxxxx
# TENCENT_SMS_SIGN_NAME=趁早行动
# TENCENT_SMS_TEMPLATE_ID=123456
# TENCENT_SMS_REGION=ap-guangzhou

# TENCENT_SMS_REGION=ap-guangzhou

# --- DeepSeek AI（计划生成，推荐）---
# 在 https://platform.deepseek.com/ 创建 API Key
# 文件位置：backend/.env（复制 .env.example 后填写）
# DEEPSEEK_API_KEY=sk-你的密钥
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# 可选 OpenAI 兼容接口（未配置 DeepSeek 时使用）
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# 微信 H5 登录
# WECHAT_APP_ID=wx_xxx
# WECHAT_APP_SECRET=xxx
# WECHAT_OAUTH_REDIRECT=http://localhost:5173/auth/wechat/callback
# WECHAT_DEV_MODE=true

# 微信支付 V3（配置后启用真实统一下单）
# WECHAT_MCH_ID=1234567890
# WECHAT_MCH_SERIAL_NO=证书序列号
# WECHAT_MCH_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
# 或直接写入私钥（\n 换行）：
# WECHAT_MCH_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# WECHAT_PAY_API_V3_KEY=32位APIv3密钥
# WECHAT_PAY_NOTIFY_URL=https://你的域名/api/member/pay/notify

# FCM 推送（Firebase 控制台 → 项目设置 → 云消息传递 → 服务器密钥）
# FCM_SERVER_KEY=AAAAxxxx
